{
  "slug": "magic-and-crab",
  "title": "魔法与螃蟹",
  "interactive": true,
  "timeLimitMs": 2000,
  "memoryLimitMb": 1024,
  "standard": "gnu++20",
  "statement": "docs/statement.md",
  "tutorial": "docs/tutorial.md",
  "validator": "src/validator/validator.cpp",
  "generator": {
    "path": "src/generator/generator.cpp",
    "cases": [
      { "name": "sample-1", "type": "sample", "seed": 1, "group": "sample" },
      { "name": "min-1", "type": "min", "seed": 2, "group": "secret" },
      { "name": "random-small-1", "type": "random-small", "seed": 3, "group": "secret", "checkWith": ["solution2", "python"] },
      { "name": "random-large-1", "type": "random-large", "seed": 4, "group": "secret" },
      { "name": "max-1", "type": "max", "seed": 5, "group": "secret" }
    ]
  },
  "interactor": "src/checker/interactor.cpp",
  "build": {
    "cppCompiler": "g++",
    "cppFlags": ["-std={{standard}}", "-O2", "-pipe"],
    "pythonCommand": "python"
  },
  "solutions": [
    { "name": "main", "path": "src/solution.cpp", "language": "cpp", "role": "main" },
    { "name": "solution2", "path": "src/solution2.cpp", "language": "cpp", "role": "reference" },
    { "name": "python", "path": "src/solution.py", "language": "python", "role": "reference" }
  ],
  "wrongSolutions": [
    { "name": "wrong-constant", "path": "src/wrong/wrong-constant.cpp", "language": "cpp", "expected": "fail" },
    { "name": "wrong-six", "path": "src/wrong/wrong-six.cpp", "language": "cpp", "expected": "fail" }
  ]
}
